# Server
NODE_ENV=development
PORT=5000
HEALTH_PORT=5001
CORS_ORIGIN=*

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/nxtmarket

# PostgreSQL (Sequelize)
SQL_HOST=127.0.0.1
SQL_PORT=5432
SQL_DB=nxtmarket
SQL_USER=postgres
SQL_PASSWORD=your_password

# JWT
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# Redis (optional bonus)
REDIS_ENABLED=false
REDIS_URL=redis://127.0.0.1:6379
